{
  "name": "neuropost",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm run dev:server && npm run dev:client",
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "build": "pnpm build:server && pnpm build:client",
    "build:server": "npm run build -w server",
    "build:client": "npm run build -w client",
    "start": "npm run start:server -w server & npm run start:client -w client",
    "start:server": "npm run start --workspace=server",
    "start:client": "npm run start --workspace=client",
    "lint": "npm run lint:server && npm run lint:client",
    "lint:client": "npm run lint --workspace=client",
    "lint:server": "npm run lint --workspace=server",
    "lint:fix": "npm run lint:server:fix && npm run lint:client:fix",
    "lint:server:fix": "npm run lint:fix --workspace=client",
    "lint:client:fix": "npm run lint:fix --workspace=server",
    "prettier": "npm run prettier:server && npm run prettier:client",
    "prettier:client": "npm run prettier:fix --workspace=client",
    "prettier:server": "npm run prettier:fix --workspace=server",
    "prettier:check": "npm run prettier:server:check && npm run prettier:client:check",
    "prettier:client:check": "npm run prettier:check --workspace=client",
    "prettier:server:check": "npm run prettier:check --workspace=server",
    "typecheck": "npm run typecheck:server && npm run typecheck:client",
    "typecheck:server": "npm run typecheck --workspace=server",
    "typecheck:client": "npm run typecheck --workspace=client",
    "clean": "npm run clean:server && npm run clean:client && rimraf node_modules",
    "clean:client": "npm run clean --workspace=client",
    "clean:server": "npm run clean --workspace=server",
    "test": "npm run test -w server",
    "test:run": "npm run test:run -w server"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "typescript": "^5.9.3",
    "eslint": "^9",
    "prettier": "^3.8.1"
  }
}
